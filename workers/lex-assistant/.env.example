# ============================================================
# Lex Worker — variabili & secret
#
# Le `vars` vanno in wrangler.toml (file sopra).
# I `secret` vanno settati con: wrangler secret put NOME
# ============================================================

# === SECRETS (mai committati) ===
# Da Anthropic Console (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# Da Supabase project settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Da Resend dashboard (per email transazionali fase 2)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# === SETUP iniziale ===
# 1. Crea KV namespace: wrangler kv:namespace create RATE_LIMIT
#    Aggiorna wrangler.toml con l'id ricevuto
# 2. wrangler secret put ANTHROPIC_API_KEY
# 3. wrangler secret put SUPABASE_SERVICE_ROLE_KEY
# 4. wrangler secret put RESEND_API_KEY
# 5. wrangler deploy --env production
