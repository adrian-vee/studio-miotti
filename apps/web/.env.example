# ============================================================
# studiomiotti.it — Frontend env example
# Copia in apps/web/.env.local e sostituisci i valori
# ============================================================

# Sito
NEXT_PUBLIC_SITE_URL=https://studiomiotti.it

# Supabase (Frankfurt EU)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Cloudflare Worker — Lex Assistant
NEXT_PUBLIC_LEX_WORKER_URL=https://lex.studiomiotti.it

# Plausible Analytics (privacy-first)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=studiomiotti.it
